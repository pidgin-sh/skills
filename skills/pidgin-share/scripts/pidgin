#!/usr/bin/env bash
# pidgin-share skill wrapper. Auth via $PIDGIN_API_KEY. Output: API JSON on
# stdout. Exit non-zero on HTTP non-2xx; the response body (which contains
# {error, message}) still goes to stdout so the caller can parse it.

# Allow tests to source this file without running the dispatcher.
if [ "${1:-}" = "--source-only" ]; then
  __PIDGIN_SOURCE_ONLY=1
  shift
fi

set -u

API="${PIDGIN_API_BASE:-https://api.pidgin.sh}"

if [ -z "${PIDGIN_API_KEY:-}" ]; then
  echo "PIDGIN_API_KEY is not set. Create a key at https://pidgin.sh/dashboard/keys and export it." >&2
  exit 2
fi

usage() {
  cat >&2 <<'EOF'
Usage:
  pidgin me
  pidgin upload <path> [--respond | --respondents=a,b,c] [--filename NAME] [--agent SLUG] [--model ID]
  pidgin update <id> <path> [--respond | --respondents=a,b,c] [--filename NAME] [--agent SLUG] [--model ID]
  pidgin list [--limit N]
  pidgin delete <id> [--version N]
  pidgin check <id>            # non-blocking status check
  pidgin wait <id>             # ch_… single-respondent, co_… cohort
  pidgin abandon <id>          # ch_… single-respondent, co_… cohort
  pidgin recent [--since 1h|24h|7d] [--all] [--limit N] [--json]
                               # local recall: list URLs you've uploaded recently
EOF
}

detect_ct() {
  local f
  f=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
  case "$f" in
    *.html|*.htm)   echo "text/html" ;;
    *.png)          echo "image/png" ;;
    *.jpg|*.jpeg)   echo "image/jpeg" ;;
    *.gif)          echo "image/gif" ;;
    *.webp)         echo "image/webp" ;;
    *.svg)          echo "image/svg+xml" ;;
    *.pdf)          echo "application/pdf" ;;
    *.json)         echo "application/json" ;;
    *.txt|*.log)    echo "text/plain" ;;
    *.md)           echo "text/markdown" ;;
    *.csv)          echo "text/csv" ;;
    *)              echo "application/octet-stream" ;;
  esac
}

# Validate an --agent / --model flag value. On mismatch, exit 2 with a clear
# message naming the flag. Empty values exit too (the agent should omit the
# flag rather than pass an empty string).
# Bracket expression note: a literal ']' must be the first character of the
# class, and '-' must be last — otherwise BSD/GNU grep close the class early.
validate_metadata() {
  local field="$1" value="$2"
  if [ -z "$value" ]; then
    echo "pidgin: --$field requires a non-empty value" >&2
    exit 2
  fi
  if ! printf '%s' "$value" | grep -qE '^[]A-Za-z0-9._/[-]{1,64}$'; then
    echo "pidgin: invalid --$field value '$value': must match [A-Za-z0-9._/[\\]-]{1,64}" >&2
    exit 2
  fi
}

# Resolve the log path. Honors $PIDGIN_LOG_DIR; falls back to $HOME/.pidgin,
# then $XDG_STATE_HOME/pidgin. Returns non-zero if none resolvable.
log_path() {
  local dir
  if [ -n "${PIDGIN_LOG_DIR:-}" ]; then
    dir="$PIDGIN_LOG_DIR"
  elif [ -n "${HOME:-}" ]; then
    dir="$HOME/.pidgin"
  elif [ -n "${XDG_STATE_HOME:-}" ]; then
    dir="$XDG_STATE_HOME/pidgin"
  else
    return 1
  fi
  printf '%s/uploads.jsonl' "$dir"
}

# Append one JSON line to the local log. Best-effort: any failure prints a
# one-line warning to stderr and returns 0 so the calling op is unaffected.
append_log() {
  local line="$1"
  local path dir
  path=$(log_path) || {
    echo "pidgin: could not resolve log path (no \$PIDGIN_LOG_DIR/\$HOME/\$XDG_STATE_HOME)" >&2
    return 0
  }
  dir=$(dirname "$path")
  if ! mkdir -p "$dir" 2>/dev/null; then
    echo "pidgin: could not create log dir $dir" >&2
    return 0
  fi
  chmod 700 "$dir" 2>/dev/null || true
  if [ ! -f "$path" ]; then
    if ! ( umask 077 && : > "$path" ) 2>/dev/null; then
      echo "pidgin: could not create log file $path" >&2
      return 0
    fi
  fi
  if ! printf '%s\n' "$line" >> "$path" 2>/dev/null; then
    echo "pidgin: could not append to log $path" >&2
    return 0
  fi
}

# Extract a top-level scalar string field. Echoes value (no quotes) or empty.
_json_str() {
  local body="$1" key="$2"
  printf '%s' "$body" | sed -n 's/^{[^{]*"'"$key"'":"\([^"]*\)".*/\1/p' | head -n1
}

# Extract a top-level scalar number field. "null" → "null", missing → empty.
# Checks null first to avoid greedy-matching a numeric value from a nested object.
_json_num() {
  local body="$1" key="$2"
  local result
  result=$(printf '%s' "$body" | sed -n 's/^{[^{]*"'"$key"'":null[,}].*/null/p' | head -n1)
  if [ -z "$result" ]; then
    result=$(printf '%s' "$body" | sed -n 's/^{[^{]*"'"$key"'":\([0-9][0-9]*\).*/\1/p' | head -n1)
  fi
  printf '%s' "$result"
}

# Extract a nested string: "<container>":{ ... "<key>":"<val>" ... }.
_json_nested_str() {
  local body="$1" container="$2" key="$3"
  printf '%s' "$body" | sed -n 's/.*"'"$container"'":{[^}]*"'"$key"'":"\([^"]*\)".*/\1/p' | head -n1
}

# JSON-escape a string value (backslash, double-quote). No surrounding quotes.
_json_escape() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '%s' "$s"
}

# Append a kind=upload record. Argument: the upload response body (JSON).
record_upload_success() {
  local body="$1"
  local item_id url filename expires channel_handle cohort_id ts cwd_esc agent_esc model_esc

  item_id=$(_json_str "$body" "id")
  url=$(_json_str "$body" "url")
  filename=$(_json_str "$body" "current_filename")
  expires=$(_json_num "$body" "expires_at")
  channel_handle=$(_json_nested_str "$body" "channel" "handle")
  cohort_id=$(_json_nested_str "$body" "cohort" "id")

  if [ -z "$item_id" ] || [ -z "$url" ]; then
    echo "pidgin: could not parse upload response for log (item_id/url missing)" >&2
    return 0
  fi

  ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  cwd_esc=$(_json_escape "${PWD:-}")

  local line='{'
  line+='"ts":"'"$ts"'",'
  line+='"cwd":"'"$cwd_esc"'",'
  line+='"kind":"upload",'
  line+='"item_id":"'"$item_id"'",'
  line+='"url":"'"$url"'",'
  line+='"filename":"'"$filename"'",'
  if [ -z "$expires" ] || [ "$expires" = "null" ]; then
    line+='"expires_at":null'
  else
    line+='"expires_at":'"$expires"
  fi
  if [ -n "$channel_handle" ]; then
    line+=',"channel_handle":"'"$channel_handle"'"'
  fi
  if [ -n "$cohort_id" ]; then
    line+=',"cohort_id":"'"$cohort_id"'"'
  fi
  if [ -n "${PIDGIN_LAST_AGENT:-}" ]; then
    agent_esc=$(_json_escape "$PIDGIN_LAST_AGENT")
    line+=',"agent":"'"$agent_esc"'"'
  fi
  if [ -n "${PIDGIN_LAST_MODEL:-}" ]; then
    model_esc=$(_json_escape "$PIDGIN_LAST_MODEL")
    line+=',"model":"'"$model_esc"'"'
  fi
  line+='}'

  append_log "$line"
}

# Append a kind=delete tombstone. Argument: deleted item_id.
record_delete_success() {
  local item_id="$1"
  if [ -z "$item_id" ]; then
    echo "pidgin: record_delete_success called without item_id; skipping log" >&2
    return 0
  fi
  local ts
  ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  append_log '{"ts":"'"$ts"'","kind":"delete","item_id":"'"$item_id"'"}'
}

# Run a curl call. Body always goes to stdout. Non-2xx → exit 1 (with
# HTTP code on stderr); 2xx → return 0.
api_call() {
  local method="$1"; shift
  local path="$1"; shift
  local tmp code body
  tmp=$(mktemp)
  code=$(curl -sS -o "$tmp" -w "%{http_code}" -X "$method" "$API$path" \
    -H "Authorization: Bearer $PIDGIN_API_KEY" "$@")
  body=$(cat "$tmp")
  rm -f "$tmp"
  [ -n "$body" ] && printf '%s\n' "$body"
  if [ "$code" -ge 200 ] && [ "$code" -lt 300 ]; then
    return 0
  fi
  echo "pidgin: HTTP $code" >&2
  exit 1
}

# Like api_call, but stores the body in __PIDGIN_RESP_BODY and the HTTP code in
# __PIDGIN_RESP_CODE, then returns 0. Caller decides what to do with non-2xx.
__PIDGIN_RESP_BODY=""
__PIDGIN_RESP_CODE=""
api_call_capture() {
  local method="$1"; shift
  local path="$1"; shift
  local tmp
  tmp=$(mktemp)
  __PIDGIN_RESP_CODE=$(curl -sS -o "$tmp" -w "%{http_code}" -X "$method" "$API$path" \
    -H "Authorization: Bearer $PIDGIN_API_KEY" "$@")
  __PIDGIN_RESP_BODY=$(cat "$tmp")
  rm -f "$tmp"
  return 0
}

if [ -z "${__PIDGIN_SOURCE_ONLY:-}" ]; then
  cmd="${1:-}"
  [ -n "$cmd" ] || { usage; exit 2; }
  shift

  case "$cmd" in
    me)
      api_call GET /v1/me
      ;;

    upload)
      [ $# -ge 1 ] || { usage; exit 2; }
      path="$1"; shift
      respond=""
      recipients=""
      filename=""
      agent=""
      model=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --respond)        respond=1; shift ;;
          --respondents=*)  recipients="${1#--respondents=}"; shift ;;
          --respondents)    recipients="$2"; shift 2 ;;
          --filename)       filename="$2"; shift 2 ;;
          --agent)          agent="$2"; shift 2 ;;
          --agent=*)        agent="${1#--agent=}"; shift ;;
          --model)          model="$2"; shift 2 ;;
          --model=*)        model="${1#--model=}"; shift ;;
          *) echo "pidgin: unknown flag: $1" >&2; exit 2 ;;
        esac
      done
      [ -z "$agent" ] || validate_metadata agent "$agent"
      [ -z "$model" ] || validate_metadata model "$model"
      [ -f "$path" ] || { echo "pidgin: no such file: $path" >&2; exit 2; }
      [ -n "$filename" ] || filename=$(basename "$path")
      ct=$(detect_ct "$filename")
      args=(
        -H "X-Filename: $filename"
        -H "Content-Type: $ct"
        --data-binary "@$path"
      )
      [ -n "$agent" ] && args+=(-H "X-Pidgin-Agent: $agent")
      [ -n "$model" ] && args+=(-H "X-Pidgin-Model: $model")
      # --respondents implies channel-respond; setting it without --respond is fine.
      if [ -n "$recipients" ] || [ -n "$respond" ]; then
        args+=(-H "X-Pidgin-Channel: respond")
      fi
      [ -n "$recipients" ] && args+=(-H "X-Pidgin-Recipients: $recipients")
      export PIDGIN_LAST_AGENT="$agent"
      export PIDGIN_LAST_MODEL="$model"
      api_call_capture POST /v1/items "${args[@]}"
      [ -n "$__PIDGIN_RESP_BODY" ] && printf '%s\n' "$__PIDGIN_RESP_BODY"
      if [ "$__PIDGIN_RESP_CODE" -ge 200 ] && [ "$__PIDGIN_RESP_CODE" -lt 300 ]; then
        record_upload_success "$__PIDGIN_RESP_BODY"
        exit 0
      fi
      echo "pidgin: HTTP $__PIDGIN_RESP_CODE" >&2
      exit 1
      ;;

    update)
      [ $# -ge 2 ] || { usage; exit 2; }
      id="$1"; path="$2"; shift 2
      respond=""
      recipients=""
      filename=""
      agent=""
      model=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --respond)        respond=1; shift ;;
          --respondents=*)  recipients="${1#--respondents=}"; shift ;;
          --respondents)    recipients="$2"; shift 2 ;;
          --filename)       filename="$2"; shift 2 ;;
          --agent)          agent="$2"; shift 2 ;;
          --agent=*)        agent="${1#--agent=}"; shift ;;
          --model)          model="$2"; shift 2 ;;
          --model=*)        model="${1#--model=}"; shift ;;
          *) echo "pidgin: unknown flag: $1" >&2; exit 2 ;;
        esac
      done
      [ -z "$agent" ] || validate_metadata agent "$agent"
      [ -z "$model" ] || validate_metadata model "$model"
      [ -f "$path" ] || { echo "pidgin: no such file: $path" >&2; exit 2; }
      [ -n "$filename" ] || filename=$(basename "$path")
      ct=$(detect_ct "$filename")
      args=(
        -H "X-Filename: $filename"
        -H "Content-Type: $ct"
        --data-binary "@$path"
      )
      [ -n "$agent" ] && args+=(-H "X-Pidgin-Agent: $agent")
      [ -n "$model" ] && args+=(-H "X-Pidgin-Model: $model")
      if [ -n "$recipients" ] || [ -n "$respond" ]; then
        args+=(-H "X-Pidgin-Channel: respond")
      fi
      [ -n "$recipients" ] && args+=(-H "X-Pidgin-Recipients: $recipients")
      export PIDGIN_LAST_AGENT="$agent"
      export PIDGIN_LAST_MODEL="$model"
      api_call_capture PUT "/v1/items/$id" "${args[@]}"
      [ -n "$__PIDGIN_RESP_BODY" ] && printf '%s\n' "$__PIDGIN_RESP_BODY"
      if [ "$__PIDGIN_RESP_CODE" -ge 200 ] && [ "$__PIDGIN_RESP_CODE" -lt 300 ]; then
        record_upload_success "$__PIDGIN_RESP_BODY"
        exit 0
      fi
      echo "pidgin: HTTP $__PIDGIN_RESP_CODE" >&2
      exit 1
      ;;

    list)
      limit=20
      while [ $# -gt 0 ]; do
        case "$1" in
          --limit) limit="$2"; shift 2 ;;
          *) echo "pidgin: unknown flag: $1" >&2; exit 2 ;;
        esac
      done
      api_call GET "/v1/items?limit=$limit"
      ;;

    delete)
      [ $# -ge 1 ] || { usage; exit 2; }
      id="$1"; shift
      version=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --version) version="$2"; shift 2 ;;
          *) echo "pidgin: unknown flag: $1" >&2; exit 2 ;;
        esac
      done
      if [ -n "$version" ]; then
        api_call_capture DELETE "/v1/items/$id/versions/$version"
      else
        api_call_capture DELETE "/v1/items/$id"
      fi
      [ -n "$__PIDGIN_RESP_BODY" ] && printf '%s\n' "$__PIDGIN_RESP_BODY"
      if [ "$__PIDGIN_RESP_CODE" -ge 200 ] && [ "$__PIDGIN_RESP_CODE" -lt 300 ]; then
        # Only tombstone full-item deletes, not version deletes.
        if [ -z "$version" ]; then
          record_delete_success "$id"
        fi
        exit 0
      fi
      echo "pidgin: HTTP $__PIDGIN_RESP_CODE" >&2
      exit 1
      ;;

    check)
      [ $# -ge 1 ] || { usage; exit 2; }
      id="$1"
      case "$id" in
        co_*) api_call GET "/v1/cohorts/$id/wait?since=0&peek=1" ;;
        *)    api_call GET "/v1/channels/$id/wait?peek=1" ;;
      esac
      ;;

    wait)
      [ $# -ge 1 ] || { usage; exit 2; }
      id="$1"
      case "$id" in
        co_*)
          # Cohort wait: long-poll with offset, accumulate responses, exit when
          # status flips out of "open". Output is one JSON document per long-poll
          # round so the agent sees responses as they arrive.
          since=0
          while :; do
            tmp=$(mktemp)
            code=$(curl -sS -o "$tmp" -w "%{http_code}" "$API/v1/cohorts/$id/wait?since=$since" \
              -H "Authorization: Bearer $PIDGIN_API_KEY")
            body=$(cat "$tmp")
            rm -f "$tmp"
            case "$code" in
              204) continue ;;
              200)
                printf '%s\n' "$body"
                # Parse status + next without jq dependency: grep the JSON keys.
                status=$(printf '%s' "$body" | sed -n 's/.*"status":"\([^"]*\)".*/\1/p')
                next=$(printf '%s' "$body" | sed -n 's/.*"next":\([0-9]*\).*/\1/p')
                if [ "$status" != "open" ]; then exit 0; fi
                # Still open: bump since to the new offset and keep polling.
                since="${next:-$since}"
                ;;
              *)
                [ -n "$body" ] && printf '%s\n' "$body"
                echo "pidgin: HTTP $code" >&2
                exit 1
                ;;
            esac
          done
          ;;
        *)
          # Single-respondent wait (ch_… or any non-co_ id).
          while :; do
            tmp=$(mktemp)
            code=$(curl -sS -o "$tmp" -w "%{http_code}" "$API/v1/channels/$id/wait" \
              -H "Authorization: Bearer $PIDGIN_API_KEY")
            body=$(cat "$tmp")
            rm -f "$tmp"
            case "$code" in
              204) continue ;;
              200) printf '%s\n' "$body"; exit 0 ;;
              *)
                [ -n "$body" ] && printf '%s\n' "$body"
                echo "pidgin: HTTP $code" >&2
                exit 1
                ;;
            esac
          done
          ;;
      esac
      ;;

    abandon)
      [ $# -ge 1 ] || { usage; exit 2; }
      id="$1"
      case "$id" in
        co_*) api_call POST "/v1/cohorts/$id/abandon" ;;
        *)    api_call POST "/v1/channels/$id/abandon" ;;
      esac
      ;;

    recent)
      since="1h"
      cwd_filter="$PWD"
      use_cwd=1
      limit=20
      json_mode=0
      while [ $# -gt 0 ]; do
        case "$1" in
          --since)   since="$2"; shift 2 ;;
          --since=*) since="${1#--since=}"; shift ;;
          --cwd)     cwd_filter="$2"; use_cwd=1; shift 2 ;;
          --cwd=*)   cwd_filter="${1#--cwd=}"; use_cwd=1; shift ;;
          --all)     use_cwd=0; shift ;;
          --limit)   limit="$2"; shift 2 ;;
          --limit=*) limit="${1#--limit=}"; shift ;;
          --json)    json_mode=1; shift ;;
          *) echo "pidgin: unknown flag for recent: $1" >&2; exit 2 ;;
        esac
      done

      case "$since" in
        *m) window_seconds=$(( ${since%m} * 60 )) ;;
        *h) window_seconds=$(( ${since%h} * 3600 )) ;;
        *d) window_seconds=$(( ${since%d} * 86400 )) ;;
        *)  echo "pidgin: invalid --since value '$since' (use Nm, Nh, or Nd)" >&2; exit 2 ;;
      esac

      log=$(log_path) || { echo "pidgin: no recent uploads logged" >&2; exit 0; }
      if [ ! -s "$log" ]; then
        echo "pidgin: no recent uploads logged" >&2
        exit 0
      fi

      now_epoch="${PIDGIN_NOW_EPOCH:-$(date -u +%s)}"
      cutoff_epoch=$(( now_epoch - window_seconds ))

      # Pass 1: collect tombstoned item_ids (newline-separated).
      deleted=$(grep -E '"kind":"delete"' "$log" 2>/dev/null \
        | sed -n 's/.*"item_id":"\([^"]*\)".*/\1/p')

      # Pass 2: pre-compute epoch per upload line and pipe to awk for filtering/format.
      # macOS `date -j -f` parses ISO 8601; Linux `date -d` is the fallback.
      enriched=$(mktemp)
      while IFS= read -r jsonline; do
        [ -z "$jsonline" ] && continue
        case "$jsonline" in
          \{*\}) ;;            # looks like JSON object
          *) continue ;;
        esac
        kind=$(printf '%s' "$jsonline" | sed -n 's/.*"kind":"\([^"]*\)".*/\1/p')
        [ "$kind" = "upload" ] || continue
        ts=$(printf '%s' "$jsonline" | sed -n 's/.*"ts":"\([^"]*\)".*/\1/p')
        [ -n "$ts" ] || continue
        epoch=$(date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$ts" '+%s' 2>/dev/null) \
          || epoch=$(date -u -d "$ts" '+%s' 2>/dev/null) \
          || epoch=0
        printf '%s\t%s\n' "$epoch" "$jsonline"
      done < "$log" > "$enriched"

      awk_out=$(mktemp)
      awk -F '\t' \
          -v deleted="$deleted" \
          -v use_cwd="$use_cwd" \
          -v cwd="$cwd_filter" \
          -v cutoff="$cutoff_epoch" \
          -v now="$now_epoch" \
          -v limit="$limit" \
          -v json_mode="$json_mode" '
        BEGIN {
          n_del = split(deleted, _arr, "\n")
          for (i = 1; i <= n_del; i++) if (_arr[i] != "") del[_arr[i]] = 1
        }
        {
          epoch = $1 + 0
          line = $2
          if (epoch == 0) next
          if (epoch < cutoff) next

          item_id = ""
          if (match(line, /"item_id":"[^"]+"/)) {
            item_id = substr(line, RSTART, RLENGTH)
            sub(/^"item_id":"/, "", item_id); sub(/"$/, "", item_id)
          }
          if (item_id in del) next

          expires = -1
          if (match(line, /"expires_at":[0-9]+/)) {
            tok = substr(line, RSTART, RLENGTH); sub(/^"expires_at":/, "", tok)
            expires = tok + 0
            if (expires > 0 && expires < now) next
          }

          cwd_v = ""
          if (match(line, /"cwd":"[^"]+"/)) {
            cwd_v = substr(line, RSTART, RLENGTH)
            sub(/^"cwd":"/, "", cwd_v); sub(/"$/, "", cwd_v)
          }
          if (use_cwd && cwd_v != cwd) next

          url = filename = cohort = channel = ""
          if (match(line, /"url":"[^"]+"/)) {
            url = substr(line, RSTART, RLENGTH); sub(/^"url":"/, "", url); sub(/"$/, "", url)
          }
          if (match(line, /"filename":"[^"]+"/)) {
            filename = substr(line, RSTART, RLENGTH); sub(/^"filename":"/, "", filename); sub(/"$/, "", filename)
          }
          if (match(line, /"channel_handle":"[^"]+"/)) {
            channel = substr(line, RSTART, RLENGTH); sub(/^"channel_handle":"/, "", channel); sub(/"$/, "", channel)
          }
          if (match(line, /"cohort_id":"[^"]+"/)) {
            cohort = substr(line, RSTART, RLENGTH); sub(/^"cohort_id":"/, "", cohort); sub(/"$/, "", cohort)
          }

          # Sort key: epoch desc → use (10^11 - epoch) so string sort works descending.
          key = sprintf("%011d", 99999999999 - epoch)
          records[key "::" NR] = epoch SUBSEP filename SUBSEP url SUBSEP channel SUBSEP cohort SUBSEP line
          n++
        }
        END {
          # Collect keys, sort ascending (gives us desc by epoch).
          i = 0
          for (k in records) keys[++i] = k
          # Simple insertion sort (small n is fine).
          for (a = 2; a <= i; a++) {
            v = keys[a]; b = a - 1
            while (b >= 1 && keys[b] > v) { keys[b+1] = keys[b]; b-- }
            keys[b+1] = v
          }

          out = 0
          if (json_mode) printf "["
          for (a = 1; a <= i && out < limit; a++) {
            split(records[keys[a]], parts, SUBSEP)
            ep = parts[1]; fn = parts[2]; u = parts[3]; ch = parts[4]; co = parts[5]; raw = parts[6]
            if (json_mode) {
              if (out > 0) printf ","
              printf "%s", raw
            } else {
              hh = int((ep % 86400) / 3600)
              mm = int((ep % 3600) / 60)
              extra = ""
              if (co != "") extra = " (cohort " co ")"
              else if (ch != "") extra = " (channel " ch ")"
              printf "%02d:%02d  %-24s %s%s\n", hh, mm, fn, u, extra
            }
            out++
          }
          if (json_mode) printf "]\n"
        }
      ' "$enriched" > "$awk_out"

      if [ "$json_mode" -eq 1 ]; then
        cat "$awk_out"
      else
        if [ -s "$awk_out" ]; then
          cat "$awk_out"
        else
          echo "pidgin: no recent uploads logged" >&2
        fi
      fi
      rm -f "$awk_out" "$enriched"
      exit 0
      ;;

    -h|--help|help)
      usage
      exit 0
      ;;

    *)
      echo "pidgin: unknown command: $cmd" >&2
      usage
      exit 2
      ;;
  esac
fi
